# ───────────────────────────────────────────────────────────────────
# Workly - Monorepo Environment Variables Checklist
# ───────────────────────────────────────────────────────────────────
#
# Duplicate this file as '.env' in their respective app folders:
# - Server variables belong in 'apps/server/.env'
# - Mobile variables belong in 'apps/mobile/.env' (or use EAS secrets for production builds)

# ===================================================================
# 1. Express API Backend Variables (apps/server/.env)
# ===================================================================

# Core Service Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
# PostgreSQL connection string for Prisma ORM
DATABASE_URL=postgresql://postgres:postgres_password@localhost:5432/workly?schema=public

# In-Memory Cache & Session Store
# Redis connection string for Socket.io PubSub, rate limiting, and caching
REDIS_URL=redis://127.0.0.1:6379/0

# Cloud Media Storage & CDN Buckets
# Amazon S3 credentials for note document hosting and user ID card uploads
AWS_ACCESS_KEY_ID=your_aws_access_key
AWS_SECRET_ACCESS_KEY=your_aws_secret_key
AWS_S3_BUCKET_NAME=workly-media-files
AWS_REGION=ap-south-1
CDN_DISTRIBUTION_URL=https://cdn.workly.in

# AI Gateway Tokens & Keys
# Google Gemini API key for academic assistant & auto summarizer features
GEMINI_API_KEY=your_gemini_api_key
# Fallback LLM provider key if needed
LLM_API_KEY=your_inference_token

# Payment Gateway (Razorpay)
# Key ID for processing wallet balance deposits
RAZORPAY_KEY_ID=your_razorpay_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# SMS Gateway Provider (e.g. MSG91, Twilio)
# Key to send physical mobile OTP verifications
SMS_GATEWAY_API_KEY=your_sms_gateway_token

# JWT Session Authorization
# Secure secret string used to sign JWT authorization headers
JWT_SECRET=generate_a_secure_32_character_random_string


# ===================================================================
# 2. React Native Expo Mobile Variables (apps/mobile/.env)
# ===================================================================

# Local API Entry Point
# CRITICAL: For physical Expo Go devices, use your local IP address (e.g. 192.168.1.X)
# instead of 'localhost' since localhost refers to the phone itself.
EXPO_PUBLIC_API_URL=http://localhost:5000/api

# Error Tracking & Telemetry Services
# Sentry DSN configuration for mobile error monitoring
EXPO_PUBLIC_SENTRY_DSN=https://your_sentry_dsn_key@sentry.io/project-id

# PostHog API Key for product usage tracking and screen views monitoring
EXPO_PUBLIC_POSTHOG_API_KEY=your_posthog_api_key
