# Server Port
PORT=5000

# Database Configuration (PostgreSQL)
# Adjust the password/username if you have customized your local Postgres install
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/campusconnect?schema=public"

# JSON Web Token Secret
JWT_SECRET="campusconnect_secret_token_123!"

# Redis Setup (Optional, falls back to memory if empty or connection fails)
REDIS_URL="redis://localhost:6379"

# Google Gemini API Key
GEMINI_API_KEY=""
