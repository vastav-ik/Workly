# Core Environment Checklist
PORT=8080
DATABASE_URL=postgresql://user:password@localhost:5432/campusconnect
REDIS_URL=redis://localhost:6379

# Storage & CDN Buckets
AWS_ACCESS_KEY_ID=your_key
AWS_SECRET_ACCESS_KEY=your_secret
AWS_S3_BUCKET_NAME=campusconnect-media-webp
CDN_DISTRIBUTION_URL=https://cdn.campusconnect.in

# API Gateways & Credentials
LLM_API_KEY=your_inference_token
GEMINI_API_KEY=your_gemini_key
RAZORPAY_KEY_ID=your_payment_id
SMS_GATEWAY_API_KEY=your_otp_provider_token

# JWT Auth
JWT_SECRET=change_this_to_a_secure_random_string
